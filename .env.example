# HTTP port (optional, default 3000)
PORT=3000

# GitHub Personal Access Tokens for authenticated API calls (round-robin).
# At least PAT_1 is required. Create tokens under:
# GitHub > Settings > Developer settings > Personal access tokens
PAT_1=
# PAT_2=
# PAT_3=

# Trust X-Forwarded-For (needed for correct client IP behind Nginx/Traefik/Cloudflare).
# Never enable if the app is exposed directly without a trusted reverse proxy —
# clients could spoof IPs and weaken rate limiting.
# Values: "true" | "false" | comma-separated IP allow list. Default: false.
TRUST_PROXY=false

# Comma-separated GitHub usernames to pre-warm in the background.
# The service refreshes these users' data before the cache expires,
# eliminating cold-start latency on first request after expiry.
# WARM_USERNAMES=ESousa97

# Background cache-warming interval in milliseconds (default: 60000 = 1 minute).
# Minimum is 30000 (30 s). Warming only triggers when cached data has actually expired.
# WARM_INTERVAL_MS=60000
