# Porta HTTP (opcional, padrão 3000)
PORT=3000

# Personal Access Tokens do GitHub para chamadas autenticadas (round-robin).
# Pelo menos PAT_1 é obrigatório. Crie em:
# GitHub > Settings > Developer Settings > Personal Access Tokens
PAT_1=
# PAT_2=
# PAT_3=

# Confiar em X-Forwarded-For (necessário para rate-limit funcionar corretamente
# atrás de Nginx/Traefik/Cloudflare). NUNCA habilite se a app for exposta
# diretamente — atacante poderia forjar o IP e bypassar rate-limit.
# Valores: "true" | "false" | lista de IPs separados por vírgula. Padrão: false.
TRUST_PROXY=false
