{
  "name": "engineering-overview-pro",
  "version": "1.0.0",
  "description": "Self-hosted SVG card generator for GitHub profile stats",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "spell": "cspell \"**\"",
    "spell:ci": "cspell \"README.md\" \"CONTRIBUTING.md\" \"SECURITY.md\" \"CODE_OF_CONDUCT.md\" \"package.json\" \"src/graphql/**/*.ts\"",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run spell:ci && npm test && npm run build && npm audit --audit-level=high"
  },
  "keywords": [
    "github",
    "stats",
    "svg",
    "cards",
    "profile"
  ],
  "author": "Esousa97",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Esousa97/engineering-overview-pro.git"
  },
  "bugs": {
    "url": "https://github.com/Esousa97/engineering-overview-pro/issues"
  },
  "homepage": "https://github.com/Esousa97/engineering-overview-pro#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@octokit/graphql": "^8.2.1",
    "@octokit/rest": "^21.1.1",
    "date-fns": "^4.1.0",
    "fastify": "^5.3.2",
    "node-cache": "^5.1.2",
    "undici": "^8.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^3.0.8",
    "cspell": "^9.7.0",
    "eslint": "^9.22.0",
    "graphql": "^16.14.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^3.0.8"
  }
}
